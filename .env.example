# ── Anthropic (voor AI-diagnose) ──────────────────────────────
# Haal op via: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-jouw-sleutel-hier

# ── Sanity (voor blog) ────────────────────────────────────────
# Haal op via: https://sanity.io → jouw project → Settings → API
VITE_SANITY_PROJECT_ID=jouw-project-id

# ── Supabase (voor analytics dashboard) ──────────────────────
# Haal op via: https://supabase.com → jouw project → Settings → API
SUPABASE_URL=https://jouw-project.supabase.co
SUPABASE_SERVICE_KEY=jouw-service-key
